{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "Woody.Api",
    "Audience": "Woody.Api",
    "ExpirationMinutes": 15
  },
  "AuthSecurity": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15
  },
  "BetaAccess": {
    "Enabled": true
  },
  "EmailVerification": {
    "ExpirationMinutes": 10,
    "MaxAttempts": 5
  },
  "MediaStorage": {
    "Driver": "Local",
    "RootPath": "App_Data/media",
    "PublicUrlPath": "/api/media/images",
    "MaxImageSizeBytes": 10485760,
    "MaxPostVideoUploadBytes": 104857600,
    "MaxMessageVideoUploadBytes": 52428800
  },
  "R2": {
    "AccountId": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "Bucket": "",
    "PublicBaseUrl": "",
    "ServiceUrl": "",
    "Region": "auto"
  },
  "Resend": {
    "FromEmail": "no-reply@example.com",
    "FromName": "Woody"
  },
  "Billing": {
    "Stripe": {
      "SecretKey": "",
      "WebhookSecret": "",
      "CheckoutSuccessUrl": "http://localhost:5173/assinatura/sucesso?session_id={CHECKOUT_SESSION_ID}",
      "CheckoutCancelUrl": "http://localhost:5173/assinatura/cancelado",
      "CustomerPortalReturnUrl": "http://localhost:5173/planos",
      "CustomerPortalConfigurationId": "",
      "PriceIds": {
        "ProMonthly": "",
        "ProAnnual": "",
        "MaxMonthly": "",
        "MaxAnnual": "",
        "CommunityPremiumMonthly": "",
        "CommunityPremiumAnnual": ""
      }
    }
  }
}
