# Copie para .env na raiz do backend (o ficheiro .env não é commitado).
# Valores alinhados com docker-compose.yml (Postgres local).
# Não reutilize estes valores em produção.

# Controla seed (Development) e logs sensíveis do EF em runtime. Use Production para simular prod local.
# IMPORTANTE: se correr `dotnet run --launch-profile ...` com variáveis ASPNETCORE_* no launchSettings,
# essas variáveis podem SOBREPOR o .env — prefira .\run-api.ps1 ou `dotnet run --no-launch-profile`.
ASPNETCORE_ENVIRONMENT=Development

# Connection string Npgsql (use aspas se tiver ; na password)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=woody_db;Username=woody_user;Password=woody@123

# JWT — use um segredo forte, único por ambiente, e nunca commitado.
# Em produção a API exige mínimo de 32 caracteres.
Jwt__Secret=altere-para-um-segredo-local-com-pelo-menos-32-caracteres!!

# Resend (envio de e-mails transacionais)
Resend__ApiKey=re_xxxxxxxxxxxxxxxxxxxxxxxxx
Resend__FromEmail=no-reply@seudominio.com
# Opcional
Resend__FromName=Woody

# Verificação de e-mail (OTP)
EmailVerification__ExpirationMinutes=10
EmailVerification__MaxAttempts=5

# Pré-inscrição (POST /api/prelaunch/signups)
# PRELAUNCH_HASH_SECRET ou PreLaunch__HashSecret — segredo para hash de IP/UA
# PreLaunch__SignupsEnabled=true   — default; false encerra a coleta de pré-inscrições (410 Gone)

# Produção: defina CORS_ORIGINS com as origens exatas do frontend (sem wildcard).
# CORS_ORIGINS=https://app.seudominio.com

# Nunca habilite seed de desenvolvimento em produção.
# WOODY_ENABLE_DEV_SEED=false

# Opcional para troubleshooting local de migrations. Não use em CI/produção.
# WOODY_EF_ENABLE_SENSITIVE_LOGGING=false

# Opcional (alternativa à connection string acima)
# DATABASE_URL=postgresql://woody_user:woody%40123@localhost:5432/woody_db

# GIF/stickers no chat (Klipy). Sem Provider=Klipy a API usa o catálogo local de demo.
# GifStickerSearch__Provider=Klipy
# GifStickerSearch__Klipy__ApiKey=sua_chave_em_klipy_com_developers

# ─── Cloudflare R2 — Mídia pública/social ─────────────────────────────────────
# Ativa o driver R2/S3 para mídia pública (posts, mensagens, avatares, banners).
# Sem esta variável (ou com Driver=Local), a API usa disco local em App_Data/media/.
# MediaStorage__Driver=S3

# Bucket: woody-media-public-dev (dev) ou woody-media-public-prod (prod)
# R2_ACCOUNT_ID=<cloudflare_account_id>
# R2_ACCESS_KEY_ID=<r2_access_key_id>
# R2_SECRET_ACCESS_KEY=<r2_secret_access_key>
# R2_BUCKET=woody-media-public-dev

# URL pública do bucket (custom domain ou r2.dev). Sem esta variável, URLs caem no proxy /api/media/...
# R2_PUBLIC_BASE_URL=https://media-dev.thewoody.co

# ─── Open Graph / partilha externa ─────────────────────────────────────────────
# PublicShare__FrontendPublicOrigin=http://localhost:5173
# PublicShare__PublicShareBaseUrl=https://api.seudominio.com
# PublicShare__ApiPublicOrigin=https://api.seudominio.com
# PublicShare__OgFallbackImageUrl=https://app.seudominio.com/icon-512.png

# Opcionais (R2 aceita defaults abaixo)
# R2_REGION=auto
# R2_SERVICE_URL=    (vazio = https://{account_id}.r2.cloudflarestorage.com)

# ─── Cloudflare R2 — Documentos de verificação de identidade (PRIVADO) ────────
# Bucket SEPARADO do de mídia pública. Nunca habilitar acesso público neste bucket.
# Documentos são acessíveis APENAS pelo endpoint SuperAdmin via streaming no backend.
# VerificationStorage__Driver=S3

# Bucket: woody-verification-private-dev (dev) ou woody-verification-private-prod (prod)
# VerificationR2__AccountId=<cloudflare_account_id>
# VerificationR2__AccessKeyId=<r2_access_key_id_para_bucket_privado>
# VerificationR2__SecretAccessKey=<r2_secret_access_key_para_bucket_privado>
# VerificationR2__Bucket=woody-verification-private-dev

# Opcionais
# VerificationR2__Region=auto
# VerificationR2__ServiceUrl=
# VerificationR2__PresignedUrlExpiryMinutes=5
