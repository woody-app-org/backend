# Copie para .env na raiz do backend (o ficheiro .env não é commitado).
# Valores alinhados com docker-compose.yml (Postgres local).

# Connection string Npgsql (use aspas se tiver ; na password)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=woody_db;Username=woody_user;Password=woody@123

# JWT — mínimo 32 caracteres recomendado em produção; em Development basta não estar vazio
Jwt__Secret=altere-para-um-segredo-local-com-pelo-menos-32-caracteres!!

# Resend (envio de e-mails transacionais)
Resend__ApiKey=re_xxxxxxxxxxxxxxxxxxxxxxxxx
Resend__FromEmail=no-reply@seudominio.com
# Opcional
Resend__FromName=Woody

# Verificação de e-mail (OTP)
EmailVerification__ExpirationMinutes=10
EmailVerification__MaxAttempts=5

# Opcional (alternativa à connection string acima)
# DATABASE_URL=postgresql://woody_user:woody%40123@localhost:5432/woody_db
